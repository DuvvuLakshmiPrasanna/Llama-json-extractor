# Environment Configuration Example
# Copy this to .env and fill in your values

# Model Configuration
MODEL_PATH=./model
MODEL_DTYPE=float16
DEVICE_MAP=auto

# Inference Parameters
MAX_NEW_TOKENS=300
TEMPERATURE=0.1
TOP_P=0.9

# Gradio Configuration
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=False

# API Keys (if using cloud APIs)
TOGETHER_API_KEY=
REPLICATE_API_KEY=
HUGGINGFACE_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Performance
BATCH_SIZE=1
ENABLE_CACHE=True
CACHE_CONFIG=.cache
